<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-feature android:name="android.hardware.type.watch" />

    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Required since targetSdk 34 (Android 14): a foreground service must declare its type
         and hold the matching permission, or startForeground() throws. WatchMusicService keeps
         the phone connection alive while music plays / the UI is open and shows a transport
         OngoingActivity, so mediaPlayback is the closest-fitting type. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <!-- targetSdk 33+ (Android 13): notifications, including the foreground service's
         OngoingActivity, require this permission. Requested once at runtime in MainActivity so
         the notification keeps showing as it did pre-33. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".watch.WearMusicCenter"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name_short"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        tools:ignore="AllowBackup,GoogleAppIndexingWarning">
        <uses-library
            android:name="com.google.android.wearable"
            android:required="true" />
        <!--
               Set to true if your app is Standalone, that is, it does not require the handheld
               app to run.
        -->
        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="false" />

        <activity
            android:name=".watch.view.MainActivity"
            android:label="@string/app_name_short"
            android:exported="true"
            android:launchMode="singleInstance">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name="com.matejdro.wearutils.companionnotice.PhoneAppNoticeActivity" />

        <service
            android:name=".watch.communication.PreferencesReceiver"
            android:exported="true"
            tools:ignore="ExportedService">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <data
                    android:host="*"
                    android:pathPrefix="/Settings"
                    android:scheme="wear" />
            </intent-filter>
        </service>

        <service
            android:name=".watch.communication.MusicCenterLogRequestReceiver"
            android:exported="true"
            tools:ignore="ExportedService">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />

                <data
                    android:host="*"
                    android:pathPrefix="/SendLogs"
                    android:scheme="wear" />
            </intent-filter>
        </service>

        <service
            android:name=".watch.communication.IdleMessageListener"
            android:exported="true"
            tools:ignore="ExportedService">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data
                    android:host="*"
                    android:pathPrefix="/IdleMessages"
                    android:scheme="wear" />
            </intent-filter>
        </service>


        <service android:name="com.matejdro.wearutils.logging.LogTransmitter" />

        <service
            android:name="pl.tajchert.exceptionwear.ExceptionService"
            android:permission="android.permission.BIND_JOB_SERVICE" />

        <service
            android:name=".watch.communication.WatchMusicService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <activity
            android:name="androidx.wear.activity.ConfirmationActivity"
            android:exported="false" />

        <activity
            android:name=".watch.view.queue.QueueActivity"
            android:exported="false"
            android:theme="@style/QueueTheme"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:noHistory="true" />
    </application>

</manifest>
