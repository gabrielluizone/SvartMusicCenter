<?xml version="1.0" encoding="utf-8"?>
<!-- Subtle lifted-dark fill, no border. A corner radius this large always clamps to half the
     row's actual height at draw time, guaranteeing a true stadium/cylinder shape regardless of
     how tall the row ends up. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/queue_pill_fill" />
    <corners android:radius="999dp" />
</shape>
