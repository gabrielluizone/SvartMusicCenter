<?xml version="1.0" encoding="utf-8"?>
<!-- Same translucent glass fill as the like/shuffle/repeat buttons (glass_pill_background.xml) -
     this bubble sits over the same blurred album art they do, so it should match them rather
     than read as a flat opaque gray. A corner radius this large always clamps to half the row's
     actual height at draw time, guaranteeing a true stadium/cylinder shape. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/glass_surface_fill" />
    <corners android:radius="999dp" />
</shape>
