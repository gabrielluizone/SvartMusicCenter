<?xml version="1.0" encoding="utf-8"?>
<!-- Stadium/capsule shape (flat top+bottom, fully rounded left+right ends) for the quick-action
     buttons - a plain oval stretches into a lopsided ellipse on a non-square view, which reads
     as "a circle forced into shape" rather than the two-half-circles-joined-by-a-straight-bridge
     look those buttons are meant to have. The radius is intentionally larger than any real
     button height so it always clamps to a true stadium regardless of size. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/glass_surface_fill" />
    <corners android:radius="999dp" />
</shape>
