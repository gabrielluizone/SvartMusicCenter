<?xml version="1.0" encoding="utf-8"?>
<!-- Plain black instead of the translucent "glass" fill used elsewhere - there's no real blur
     behind this list, so a flat black reads better than a washed-out gray. Large radius clamps
     to half the row's actual height at draw time, always rendering as a true cylinder/stadium
     shape rather than a rounded rectangle. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@android:color/black" />
    <corners android:radius="999dp" />
</shape>
