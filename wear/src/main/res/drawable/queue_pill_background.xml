<?xml version="1.0" encoding="utf-8"?>
<!-- Large radius clamps to half the row's actual (now much thinner) height at draw time,
     so this always renders as a true cylinder/stadium shape rather than a rounded rectangle. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_surface_fill" />
            <corners android:radius="999dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <corners android:radius="999dp" />
            <stroke
                android:width="1dp"
                android:color="@color/glass_surface_border" />
        </shape>
    </item>
</layer-list>
