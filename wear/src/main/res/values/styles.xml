<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="AppTheme" parent="Theme.AppCompat.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/theme_accent</item>
        <item name="colorPrimaryDark">@color/theme_accent</item>
        <item name="colorAccent">@color/theme_accent</item>
        <item name="android:fontFamily">@font/google_sans</item>
        <item name="fontFamily">@font/google_sans</item>
    </style>

    <!-- QueueActivity is a Compose screen: black window background (no gray launch flash), no
         window animation (the SwipeToDismissBox animates the close itself - a window animation on
         top of it looked like the screen closing twice), and no system swipe-to-dismiss (Compose
         handles the swipe, so the system one must not also fire). -->
    <style name="QueueTheme" parent="@android:style/Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowSwipeToDismiss">false</item>
    </style>
</resources>