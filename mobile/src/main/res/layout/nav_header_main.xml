<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/lyra_background">

    <!-- App Logo / Icon -->
    <ImageView
        android:id="@+id/drawer_app_logo"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginTop="32dp"
        android:src="@mipmap/ic_launcher"
        android:background="@drawable/mini_album_bg"
        android:padding="12dp"
        android:clipToOutline="true"
        android:layout_gravity="center_horizontal" />

    <!-- App Name -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/app_name"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/lyra_on_surface"
        android:fontFamily="@font/google_sans"
        android:gravity="center_horizontal" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Companion App"
        android:textSize="12sp"
        android:textColor="@color/lyra_text_secondary"
        android:fontFamily="@font/google_sans"
        android:gravity="center_horizontal" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        android:background="@color/lyra_divider" />

    <!-- About Section Info (in English) -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ABOUT"
        android:textSize="11sp"
        android:letterSpacing="0.08"
        android:textAllCaps="true"
        android:textColor="@color/lyra_accent"
        android:fontFamily="@font/google_sans"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Control and synchronize music between your Android smartphone and Wear OS smartwatch."
        android:textSize="14sp"
        android:textColor="@color/lyra_on_surface"
        android:lineSpacingMultiplier="1.2"
        android:fontFamily="@font/google_sans" />

    <!-- Spacer to push version info to the bottom -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Version Info -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Version 1.0.0"
        android:textSize="11sp"
        android:textColor="@color/lyra_text_secondary"
        android:fontFamily="@font/google_sans"
        android:gravity="center_horizontal" />

</LinearLayout>
