<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp"
        tools:minHeight="500dp">

        <!-- Section header: On-screen buttons -->
        <TextView
            android:id="@+id/on_screen_buttons_caption"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="20dp"
            android:fontFamily="@font/google_sans"
            android:letterSpacing="0.08"
            android:text="@string/on_screen_buttons"
            android:textAllCaps="true"
            android:textColor="@color/lyra_accent"
            android:textSize="11sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Hint -->
        <TextView
            android:id="@+id/on_screen_hint"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="2dp"
            android:layout_marginEnd="20dp"
            android:fontFamily="@font/google_sans"
            android:text="@string/tap_a_zone_to_configure"
            android:textColor="@color/lyra_pref_summary"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/on_screen_buttons_caption" />

        <!-- Watch face: fixed-size dark preview, centered. Margem superior aumentada para mais teto -->
        <ImageView
            android:id="@+id/watch_display_background"
            android:layout_width="244dp"
            android:layout_height="244dp"
            android:layout_marginTop="40dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/on_screen_hint"
            tools:ignore="ContentDescription"
            tools:src="@drawable/watch_round_background" />

        <com.matejdro.wearmusiccenter.common.view.FourWayTouchLayout
            android:id="@+id/four_way_touch"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="@+id/watch_display_background"
            app:layout_constraintEnd_toEndOf="@+id/watch_display_background"
            app:layout_constraintStart_toStartOf="@+id/watch_display_background"
            app:layout_constraintTop_toTopOf="@+id/watch_display_background" />

        <ImageView
            android:id="@+id/watch_display_border"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="@+id/watch_display_background"
            app:layout_constraintEnd_toEndOf="@+id/watch_display_background"
            app:layout_constraintStart_toStartOf="@+id/watch_display_background"
            app:layout_constraintTop_toTopOf="@+id/watch_display_background"
            tools:ignore="ContentDescription"
            tools:src="@drawable/watch_round_border" />

        <!-- Top zone icon -->
        <ImageView
            android:id="@+id/icon_top"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="20dp"
            android:padding="10dp"
            app:layout_constraintEnd_toEndOf="@+id/watch_display_background"
            app:layout_constraintStart_toStartOf="@+id/watch_display_background"
            app:layout_constraintTop_toTopOf="@+id/watch_display_background"
            tools:ignore="ContentDescription"
            tools:src="@drawable/action_volume_up"
            tools:tint="#FFFFFF" />

        <!-- Bottom zone icon -->
        <ImageView
            android:id="@+id/icon_bottom"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="20dp"
            android:padding="10dp"
            app:layout_constraintBottom_toBottomOf="@+id/watch_display_background"
            app:layout_constraintEnd_toEndOf="@+id/watch_display_background"
            app:layout_constraintStart_toStartOf="@+id/watch_display_background"
            tools:ignore="ContentDescription"
            tools:src="@drawable/action_volume_down"
            tools:tint="#FFFFFF" />

        <!-- Left zone icon -->
        <ImageView
            android:id="@+id/icon_left"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="20dp"
            android:padding="10dp"
            app:layout_constraintBottom_toBottomOf="@+id/watch_display_background"
            app:layout_constraintStart_toStartOf="@+id/watch_display_background"
            app:layout_constraintTop_toTopOf="@+id/watch_display_background"
            tools:ignore="ContentDescription"
            tools:src="@drawable/action_skip_prev"
            tools:tint="#FFFFFF" />

        <!-- Right zone icon -->
        <ImageView
            android:id="@+id/icon_right"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="20dp"
            android:padding="10dp"
            app:layout_constraintBottom_toBottomOf="@+id/watch_display_background"
            app:layout_constraintEnd_toEndOf="@+id/watch_display_background"
            app:layout_constraintTop_toTopOf="@+id/watch_display_background"
            tools:ignore="ContentDescription"
            tools:src="@drawable/action_skip_next"
            tools:tint="#FFFFFF" />

        <!-- Divider. Margem superior aumentada para dar mais chão -->
        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="56dp"
            android:layout_marginEnd="20dp"
            android:background="@color/lyra_divider"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/watch_display_background" />

        <!-- Section header: Physical buttons -->
        <TextView
            android:id="@+id/caption_physical_buttons"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="20dp"
            android:fontFamily="@font/google_sans"
            android:letterSpacing="0.08"
            android:text="@string/physical_buttons"
            android:textAllCaps="true"
            android:textColor="@color/lyra_accent"
            android:textSize="11sp"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/divider" />

        <!-- Physical button list -->
        <LinearLayout
            android:id="@+id/watch_button_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="20dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/caption_physical_buttons" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
