<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/lyra_background">

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/app_bar_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/lyra_background"
            app:elevation="0dp">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@color/lyra_background"
                app:titleTextColor="@color/lyra_on_surface"
                app:subtitleTextColor="@color/lyra_text_secondary"
                app:titleTextAppearance="@style/LyraToolbarTitle" />

    </com.google.android.material.appbar.AppBarLayout>

    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="72dp"
        android:src="@drawable/ic_plus"
        android:visibility="gone"
        app:backgroundTint="@color/lyra_accent"
        app:tint="@color/lyra_white"
        app:elevation="4dp" />

    <!-- Play FAB: shown when nothing is playing -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_play"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="76dp"
        android:src="@drawable/ic_nav_playing"
        android:visibility="gone"
        app:backgroundTint="@color/lyra_accent"
        app:tint="@color/lyra_white"
        app:elevation="6dp"
        app:fabSize="normal" />

    <!-- Bottom container: mini player + navigation bar -->
    <LinearLayout
        android:id="@+id/bottom_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical">

        <!-- Thin separator between content and bottom area -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/lyra_divider" />

        <!-- Mini player — shown when music is active -->
        <LinearLayout
            android:id="@+id/mini_player"
            android:layout_width="match_parent"
            android:layout_height="@dimen/mini_player_height"
            android:orientation="vertical"
            android:background="@color/lyra_background"
            android:visibility="gone">

            <!-- Playback progress bar: thin line but draggable -->
            <SeekBar
                android:id="@+id/mini_progress"
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:paddingStart="0dp"
                android:paddingEnd="0dp"
                android:minHeight="2dp"
                android:max="1000"
                android:progress="0"
                android:progressTint="@color/lyra_accent"
                android:progressBackgroundTint="@color/lyra_divider"
                android:thumb="@drawable/seekbar_thumb_small"
                android:splitTrack="false" />

            <!-- Content row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="8dp">

                <!-- Metadata container (clickable to expand) -->
                <LinearLayout
                    android:id="@+id/mini_metadata_container"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?selectableItemBackground">

                    <!-- Album art thumbnail -->
                    <ImageView
                        android:id="@+id/mini_album_art"
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:layout_marginEnd="12dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_music_note"
                        android:background="@drawable/mini_album_bg"
                        android:clipToOutline="true" />

                    <!-- Song info -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/mini_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/lyra_on_surface"
                            android:fontFamily="@font/google_sans"
                            android:singleLine="true"
                            android:ellipsize="marquee"
                            android:marqueeRepeatLimit="marquee_forever"
                            android:scrollHorizontally="true"
                            android:focusable="true"
                            android:focusableInTouchMode="true"
                            android:includeFontPadding="false"
                            android:text="—" />

                        <TextView
                            android:id="@+id/mini_artist"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="@color/lyra_text_secondary"
                            android:fontFamily="@font/google_sans"
                            android:singleLine="true"
                            android:ellipsize="marquee"
                            android:marqueeRepeatLimit="marquee_forever"
                            android:scrollHorizontally="true"
                            android:focusable="true"
                            android:focusableInTouchMode="true"
                            android:includeFontPadding="false"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>
                </LinearLayout>

                <!-- Previous -->
                <ImageButton
                    android:id="@+id/mini_prev"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_mini_prev"
                    android:background="?selectableItemBackgroundBorderless"
                    android:padding="8dp"
                    android:contentDescription="@string/action_skip_prev"
                    android:tint="@color/lyra_text_secondary" />

                <!-- Play / Pause -->
                <ImageButton
                    android:id="@+id/mini_play_pause"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_nav_playing"
                    android:background="?selectableItemBackgroundBorderless"
                    android:padding="8dp"
                    android:layout_marginStart="2dp"
                    android:layout_marginEnd="2dp"
                    android:contentDescription="@string/action_play"
                    android:tint="@color/lyra_accent" />

                <!-- Next -->
                <ImageButton
                    android:id="@+id/mini_next"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_mini_next"
                    android:background="?selectableItemBackgroundBorderless"
                    android:padding="8dp"
                    android:contentDescription="@string/action_skip_next"
                    android:tint="@color/lyra_text_secondary" />

            </LinearLayout>

        </LinearLayout>

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/lyra_background"
            app:menu="@menu/activity_main_drawer"
            app:itemIconTint="@color/bottom_nav_item"
            app:itemTextColor="@color/bottom_nav_item"
            app:itemTextAppearanceActive="@style/LyraBottomNavLabel"
            app:itemTextAppearanceInactive="@style/LyraBottomNavLabel"
            app:labelVisibilityMode="selected"
            app:elevation="0dp" />

    </LinearLayout>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- Navigation Drawer View displaying Author information -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        app:headerLayout="@layout/nav_header_main"
        android:background="@color/lyra_background" />

</androidx.drawerlayout.widget.DrawerLayout>
