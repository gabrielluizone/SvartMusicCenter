<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Lyra Control — Material Design 2, day/night adaptive -->
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/lyra_accent</item>
        <item name="colorPrimaryDark">@color/lyra_sage_dark</item>
        <item name="colorAccent">@color/lyra_accent</item>
        <item name="colorSurface">@color/lyra_surface</item>
        <item name="colorOnSurface">@color/lyra_on_surface</item>
        <item name="android:colorBackground">@color/lyra_background</item>
        <item name="android:textColorPrimary">@color/lyra_on_surface</item>
        <item name="android:textColorSecondary">@color/lyra_text_secondary</item>
        <!-- Ripple e controles: Sage em vez de roxo -->
        <item name="colorControlNormal">@color/lyra_on_surface</item>
        <item name="colorControlActivated">@color/lyra_accent</item>
        <item name="colorControlHighlight">@color/lyra_accent_highlight</item>
        <item name="colorSwitchThumbNormal">@color/lyra_stone</item>
        <!-- Status bar adaptável ao modo -->
        <item name="android:statusBarColor">@color/lyra_background</item>
        <item name="android:windowLightStatusBar">@bool/is_light_mode</item>
        <!-- Typography -->
        <item name="android:fontFamily">@font/google_sans</item>
        <item name="fontFamily">@font/google_sans</item>
        <item name="preferenceTheme">@style/LyraPreferenceTheme</item>
    </style>

    <style name="LyraPreferenceTheme" parent="@style/PreferenceThemeOverlay.v14.Material">
        <item name="preferenceCategoryStyle">@style/LyraPreferenceCategory</item>
        <item name="preferenceCategoryTitleTextAppearance">@style/LyraPrefCategoryText</item>
    </style>

    <style name="LyraPreferenceCategory" parent="@style/Preference.Category">
        <item name="android:layout">@layout/pref_category_header</item>
    </style>

    <style name="LyraPrefCategoryText" parent="TextAppearance.AppCompat.Small">
        <item name="android:textColor">@color/lyra_accent</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="LyraToolbarTitle" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">@font/google_sans</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="AppTheme.NoActionBar">
        <item name="android:statusBarColor">@color/lyra_background</item>
        <item name="android:windowLightStatusBar">@bool/is_light_mode</item>
    </style>

    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar"/>
    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.AppCompat.Light"/>

    <style name="LyraDialogBase" parent="Theme.MaterialComponents.DayNight.Dialog">
        <item name="colorPrimary">@color/lyra_accent</item>
        <item name="colorPrimaryDark">@color/lyra_sage_dark</item>
        <item name="colorAccent">@color/lyra_accent</item>
        <item name="colorSurface">@color/lyra_surface</item>
        <item name="colorOnSurface">@color/lyra_on_surface</item>
        <item name="android:colorBackground">@color/lyra_surface</item>
        <item name="android:windowBackground">@drawable/dialog_bg_lyra</item>
        <item name="android:textColorPrimary">@color/lyra_on_surface</item>
        <item name="android:textColorSecondary">@color/lyra_text_secondary</item>
        <item name="colorControlNormal">@color/lyra_on_surface</item>
        <item name="colorControlActivated">@color/lyra_accent</item>
        <item name="colorControlHighlight">@color/lyra_accent_highlight</item>
        <item name="android:fontFamily">@font/google_sans</item>
        <item name="fontFamily">@font/google_sans</item>
    </style>

    <style name="AppTheme.Dialog" parent="LyraDialogBase">
        <item name="android:windowMinWidthMajor">90%</item>
        <item name="android:windowMinWidthMinor">90%</item>
    </style>

    <style name="AppTheme.Dialog.Short" parent="LyraDialogBase">
        <item name="android:windowMinWidthMajor">0%</item>
        <item name="android:windowMinWidthMinor">0%</item>
    </style>

    <!-- Bottom nav label: 13sp (um pouquinho maior que o padrão 12sp) -->
    <style name="LyraBottomNavLabel" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">@font/google_sans</item>
        <item name="fontFamily">@font/google_sans</item>
    </style>

    <!-- Gesture-picker action button: neutral text, subtle outline, left-aligned with icon -->
    <style name="LyraGestureButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">?android:attr/textColorPrimary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/google_sans</item>
        <item name="android:gravity">start|center_vertical</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0</item>
        <item name="strokeColor">@color/lyra_divider</item>
        <item name="rippleColor">@color/lyra_accent_highlight</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

</resources>
